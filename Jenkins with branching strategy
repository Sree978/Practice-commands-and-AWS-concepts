pipeline {
    agent any

    tools {
        maven "mymaven"
    }

    stages {

        stage('Code') {
            steps {
                git branch: 'main', url: 'https://github.com/Sree978/newproject-jenkins1.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Artifact') {
            steps {
                echo 'Artifact created successfully'
            }
        }

        stage('Deploy') {
            steps {
                deploy adapters: [
                    tomcat9(
                        credentialsId: 'tomcatadmin',
                        url: 'http://13.217.3.174:8080'
                    )
                ],
                contextPath: 'ecom-app',
                war: 'target/*.war'
            }
        }
    }
}

