Will give variable 
after a agent in pipeline
pipeline {
    agent {
        node{
            label "slave"
        }
    }
    environment {
        tools =" docker"
        topic ="aws"
        day ="sunday"
    }
    
    stages {
        stage('code') {
            steps {
                echo " welcome to $tools, class on $day "
            }
        }
    }
}

